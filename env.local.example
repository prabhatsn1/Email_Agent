# MongoDB connection string (required)
MONGODB_URI=mongodb://localhost:27017/email-agent

# Groq API key (required) — get one free at https://console.groq.com
GROQ_API_KEY=gsk_...

# Model to use (optional, defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# App URL used when configuring OAuth redirect URIs in provider consoles.
# The app reads origin from the request at runtime, so this is documentation-only.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Multi-user isolation
# Each browser session gets a secure visitor_id cookie automatically.
# No extra env vars are required for per-user data isolation.

# ── Gmail OAuth ──────────────────────────────────────────────────────────────
# 1. Go to console.cloud.google.com → New project
# 2. Enable "Gmail API"
# 3. APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# 4. Add Authorized redirect URI: http://localhost:3000/api/connect/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Outlook OAuth ────────────────────────────────────────────────────────────
# 1. Go to portal.azure.com → Azure Active Directory → App registrations → New
# 2. Add redirect URI (Web): http://localhost:3000/api/connect/outlook/callback
# 3. Certificates & secrets → New client secret
# 4. API permissions → Add: Mail.Read, User.Read, offline_access (all Delegated)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
